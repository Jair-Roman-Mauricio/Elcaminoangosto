{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "El Camino Angosto — Node / NestJS",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "isolatedModules": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "types": ["node"]
  }
}

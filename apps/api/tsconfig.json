{
  "extends": "@elcamino/config/tsconfig/node.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "declaration": false,
    "declarationMap": false,
    // Nest usa decoradores y DI por metadatos; los campos inyectados se
    // asignan fuera del constructor.
    "strictPropertyInitialization": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}

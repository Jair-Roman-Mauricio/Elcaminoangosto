# Copia a `.env` y rellena. NUNCA commitees el .env real.

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Orígenes permitidos por CORS, separados por coma.
CORS_ORIGINS=http://localhost:5173

# ─── Supabase ─────────────────────────────────────────────────────────────
# Panel: Project Settings → API
SUPABASE_URL=https://TU_PROYECTO.supabase.co

# JWKS de claves ASIMÉTRICAS (ES256/RS256). NO uses el secreto HS256 legacy.
# Panel: Project Settings → JWT Keys → "JWKS URL"
SUPABASE_JWKS_URL=https://TU_PROYECTO.supabase.co/auth/v1/.well-known/jwks.json

# Emisor esperado del token.
SUPABASE_JWT_ISSUER=https://TU_PROYECTO.supabase.co/auth/v1

# Solo para operaciones administrativas controladas. Jamás llega al navegador.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Postgres ─────────────────────────────────────────────────────────────
# Usa el POOLER en modo transacción (puerto 6543) para serverless/Railway.
DATABASE_URL=postgresql://postgres.TU_PROYECTO:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

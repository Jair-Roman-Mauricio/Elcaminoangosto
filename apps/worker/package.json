{
  "name": "@elcamino/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/main.ts --format esm --clean --target node20",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@elcamino/shared-types": "workspace:*",
    "@supabase/supabase-js": "^2.47.10",
    "bullmq": "^5.34.6",
    "ioredis": "^5.4.2",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@elcamino/config": "workspace:*",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
